# Keep portable project files such as .Rprofile, .renvignore, renv.lock,
# shared/Minerva config files, scripts/, jobs/, renv/activate.R, and
# renv/settings.json tracked.

# Generated analysis outputs and transient execution files.
logs/
tmp/
*.log
*.out
*.err
*.tmp
*.tmp.*
*.orig
*.rej

# Python build/test caches in addition to the local .venv below.
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/

# R session and IDE state.
.RData
.Rhistory
.Ruserdata
.Rproj.user/
.RDataTmp

# Machine-specific renv libraries and caches.
renv/library/
renv/local/
renv/cellar/
renv/lock/
renv/python/
renv/sandbox/
renv/staging/

# Editor and operating-system metadata.
.vscode/
.idea/
.DS_Store
Thumbs.db

# Large inputs, documentation, local environments, and scratch directories.
.venv/
__pycache__/
data/
docs/
untracked/
ad_research/

# Workstation-only local-pilot configuration; Minerva uses the shared and
# Minerva-production configuration files instead.
config/local_pilot.yml
config/local_pilot_execution.yml
config/local_pilot_rds_manifest.tsv

# ignore everything in results directory except for results/minerva_production/08_mast
results/*
!results/minerva_production
results/minerva_production/*
!results/minerva_production/01_audit
!results/minerva_production/02_cohort
!resutlts/minerva_production/03_annotations
!results/minerva_production/04_qc
!results/minerva_production/06_descriptive
!results/minerva_production/08_mast
!results/minerva_production/09_downstream
!results/minerva_production/10_downstream
!results/minerva_production/12_sensitivity
!results/minerva_production/13_power
!results/minerva_production/14_validation
!results/minerva_production/15_figures
